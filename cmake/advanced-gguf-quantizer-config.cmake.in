set(LLAMA_VERSION      @LLAMA_INSTALL_VERSION@)
set(LLAMA_BUILD_COMMIT @LLAMA_BUILD_COMMIT@)
set(LLAMA_BUILD_NUMBER @LLAMA_BUILD_NUMBER@)
set(LLAMA_SHARED_LIB   @BUILD_SHARED_LIBS@)

set(ADVANCED_GGUF_QUANTIZER_VERSION      ${LLAMA_VERSION})
set(ADVANCED_GGUF_QUANTIZER_BUILD_COMMIT ${LLAMA_BUILD_COMMIT})
set(ADVANCED_GGUF_QUANTIZER_BUILD_NUMBER ${LLAMA_BUILD_NUMBER})
set(ADVANCED_GGUF_QUANTIZER_SHARED_LIB   ${LLAMA_SHARED_LIB})

@PACKAGE_INIT@

set_and_check(LLAMA_INCLUDE_DIR "@PACKAGE_LLAMA_INCLUDE_INSTALL_DIR@")
set_and_check(LLAMA_LIB_DIR     "@PACKAGE_LLAMA_LIB_INSTALL_DIR@")
set(LLAMA_BIN_DIR "@PACKAGE_LLAMA_BIN_INSTALL_DIR@")

set(ADVANCED_GGUF_QUANTIZER_INCLUDE_DIR ${LLAMA_INCLUDE_DIR})
set(ADVANCED_GGUF_QUANTIZER_LIB_DIR     ${LLAMA_LIB_DIR})
set(ADVANCED_GGUF_QUANTIZER_BIN_DIR     ${LLAMA_BIN_DIR})

find_package(ggml REQUIRED HINTS ${LLAMA_LIB_DIR}/cmake)

find_library(llama_LIBRARY llama
    REQUIRED
    HINTS ${LLAMA_LIB_DIR}
    NO_CMAKE_FIND_ROOT_PATH
)

add_library(llama UNKNOWN IMPORTED)
set_target_properties(llama
    PROPERTIES
        INTERFACE_INCLUDE_DIRECTORIES "${LLAMA_INCLUDE_DIR}"
        INTERFACE_LINK_LIBRARIES "ggml::ggml;ggml::ggml-base;"
        IMPORTED_LINK_INTERFACE_LANGUAGES "CXX"
        IMPORTED_LOCATION "${llama_LIBRARY}"
        INTERFACE_COMPILE_FEATURES c_std_90
        POSITION_INDEPENDENT_CODE ON)

if (NOT TARGET advanced-gguf-quantizer::llama)
    add_library(advanced-gguf-quantizer::llama UNKNOWN IMPORTED)
    set_target_properties(advanced-gguf-quantizer::llama
        PROPERTIES
            INTERFACE_INCLUDE_DIRECTORIES "${ADVANCED_GGUF_QUANTIZER_INCLUDE_DIR}"
            INTERFACE_LINK_LIBRARIES "ggml::ggml;ggml::ggml-base;"
            IMPORTED_LINK_INTERFACE_LANGUAGES "CXX"
            IMPORTED_LOCATION "${llama_LIBRARY}"
            INTERFACE_COMPILE_FEATURES c_std_90
            POSITION_INDEPENDENT_CODE ON)
endif()

check_required_components(advanced-gguf-quantizer)
